      <column datatype='string' name='[:Measure Names]' role='dimension' type='nominal'>
        <aliases>
          <alias key='&quot;[federated.05nif8o0jkrg2a127ci181bs76j4].[avg:Calculation_2047861031305229:qk]&quot;' value='Actual' />
          <alias key='&quot;[federated.05nif8o0jkrg2a127ci181bs76j4].[usr:Calculation_2047860860907523:qk]&quot;' value='Estimated' />
        </aliases>
      </column>
      <column caption='Revenue' datatype='real' default-format='n#,##0;-#,##0' name='[Calculation_2047860668641280]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='sum([price])' />
      </column>
      <column caption=' Completed Orders' datatype='integer' name='[Calculation_2047860859650049]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([order_id])' />
      </column>
      <column caption=' Average Order Value' datatype='real' name='[Calculation_2047860860243970]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([price]+[freight_value])/COUNT([order_id])' />
      </column>
      <column caption=' Average Delivery Time' datatype='real' default-format='n#,##0&quot; days&quot;;-#,##0&quot; days&quot;' name='[Calculation_2047860860907523]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([order_estimated_delivery_date]-[order_purchase_timestamp])' />
      </column>
      <column caption='Customers' datatype='integer' name='[Calculation_2047860897013766]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([customer_id])' />
      </column>
      <column caption='Cnt Review id' datatype='integer' name='[Calculation_2047860980891656]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([&quot;review_id&quot;])' />
      </column>
      <column aggregation='Avg' caption='Delivery Time (Days)' datatype='integer' default-format='n#,##0.0&quot; days&quot;;-#,##0.0&quot; days&quot;' name='[Calculation_2047861031305229]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&#13;&#10;&apos;day&apos;,&#13;&#10;[order_purchase_timestamp],&#13;&#10;[order_delivered_customer_date]&#13;&#10;)' />
      </column>
      <column caption='Average Estimated Delivery Time' datatype='real' name='[Calculation_2047861035393038]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG(DATEDIFF(&#13;&#10;&apos;day&apos;,&#13;&#10;[order_purchase_timestamp],&#13;&#10;[order_estimated_delivery_date]&#13;&#10;))' />
      </column>
      <column caption='Average Delivery Difference' datatype='integer' name='[Calculation_2047861035745295]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&#13;&#10;&apos;day&apos;,&#13;&#10;[order_delivered_customer_date],&#13;&#10;[order_estimated_delivery_date]&#13;&#10;)' />
      </column>
      <column caption='Delivered On Time' datatype='integer' default-format='p0.0%' name='[Calculation_2047861036216336]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [order_delivered_customer_date] &lt;= [order_estimated_delivery_date]&#13;&#10;THEN 1&#13;&#10;ELSE 0&#13;&#10;END' />
      </column>
      <column caption='Difference' datatype='real' name='[Calculation_2047861052493842]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_2047860860907523]&#13;&#10;-AVG([Calculation_2047861031305229])' />
      </column>
      <column caption='Performance' datatype='string' datatype-customized='true' name='[Calculation_2047861053243411]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_2047861052493842] &gt;= 10 THEN&#13;&#10;&quot;⭐ Excellent&quot;&#13;&#10;&#13;&#10;ELSEIF [Calculation_2047861052493842] &gt;= 5 THEN&#13;&#10;&quot;✅ Good&quot;&#13;&#10;&#13;&#10;ELSEIF [Calculation_2047861052493842] &gt;= 0 THEN&#13;&#10;&quot;🟡 On Time&quot;&#13;&#10;&#13;&#10;ELSE&#13;&#10;&quot;🔴 Delayed&quot;&#13;&#10;&#13;&#10;END' />
      </column>
